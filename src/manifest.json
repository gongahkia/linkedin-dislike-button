{
  "manifest_version": 3,
  "name": "Respectful Reaction Button",
  "version": "2.1.0",
  "description": "Adds a draft-only reaction action on linkedin.com and fills a respectful reply without posting automatically.",
  "homepage_url": "https://github.com/gongahkia/linkedin-dislike-button",
  "permissions": ["storage"],
  "action": {
    "default_title": "Respectful Reaction Button",
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["https://www.linkedin.com/*"],
      "css": ["styles.css"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["images/dislike.png"],
      "matches": ["https://www.linkedin.com/*"]
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "respectful-reaction-button@gongahkia.dev",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  }
}
